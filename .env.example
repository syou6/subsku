# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# service role key — server only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Anthropic (server-side import / MCP) ----
ANTHROPIC_API_KEY=sk-ant-...

# OAuth bearer tokens for the connected MCP servers used by the import routes.
# In production these should be stored per-user after the user connects each service.
# For local dev / single-tenant, set them here.
STRIPE_MCP_TOKEN=
GMAIL_MCP_TOKEN=

# ---- Stripe (Burn Pro — one-time / 買い切り via Payment Link) ----
# Public Payment Link URL (Stripe Dashboard → Payment Links). Safe to expose.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/...
# Webhook signature verification (server only)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
