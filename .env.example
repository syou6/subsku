# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# service role key — server only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Anthropic (server-side import / MCP) ----
ANTHROPIC_API_KEY=sk-ant-...

# OAuth bearer tokens for the connected MCP servers used by the import routes.
# In production these should be stored per-user after the user connects each service.
# For local dev / single-tenant, set them here.
STRIPE_MCP_TOKEN=
GMAIL_MCP_TOKEN=

# ---- Stripe (Burn's own Pro billing) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price id of the Burn Pro recurring price
STRIPE_PRICE_PRO=price_...

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
